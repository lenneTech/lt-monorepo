{
  "name": "lt-monorepo",
  "version": "3.5.2",
  "description": "Monorepo starter kit",
  "author": "lenne.Tech <info@lenne.tech> (https://lenne.tech)",
  "license": "MIT",
  "scripts": {
    "c": "pnpm run check",
    "check": "node scripts/check.mjs",
    "check:raw": "pnpm install --frozen-lockfile && pnpm audit && pnpm run check:workspace && pnpm run check:pin && pnpm -r --parallel run check",
    "check:fix": "pnpm install && pnpm audit --fix && pnpm run check:workspace && pnpm run check:pin && pnpm -r --parallel run check:fix",
    "check:naf": "pnpm install && pnpm run check:workspace && pnpm run check:pin && pnpm -r --parallel run check:naf",
    "check:workspace": "node scripts/check-workspace-consistency.mjs",
    "check:pin": "node scripts/check-packagemanager-pin.mjs",
    "cf": "pnpm run check:fix",
    "cnaf": "pnpm run check:naf",
    "init": "pnpm install && pnpm -r --parallel run init",
    "dev": "lt dev up",
    "dev:down": "lt dev down",
    "dev:status": "lt dev status",
    "dev:doctor": "lt dev doctor",
    "start": "pnpm -r --parallel run start",
    "start:develop": "pnpm -r --parallel run start:develop",
    "start:test": "pnpm -r --parallel run start:test",
    "start:prod": "pnpm -r --parallel run start:prod",
    "build": "pnpm -r --parallel run build",
    "app:build": "pnpm -r --parallel run app:build",
    "build:develop": "pnpm -r --parallel run build:develop",
    "build:test": "pnpm -r --parallel run build:test",
    "build:prod": "pnpm -r --parallel run build:prod",
    "test": "pnpm -r --parallel run test",
    "api:test": "cd projects/api && pnpm run test:ci",
    "app:test": "cd projects/app && pnpm run test",
    "lint": "pnpm -r --parallel run lint",
    "lint:fix": "pnpm -r --parallel run lint:fix",
    "format": "pnpm -r --parallel run format",
    "format:check": "pnpm -r --parallel run format:check",
    "reinit": "rm -rf node_modules && rm -rf pnpm-lock.yaml && pnpm install && pnpm -r --parallel run reinit",
    "prepare": "husky || true",
    "release": "commit-and-tag-version",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major"
  },
  "devDependencies": {
    "commit-and-tag-version": "12.7.3",
    "husky": "9.1.7"
  },
  "engines": {
    "node": ">= 22",
    "pnpm": "^11.0.0"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25"
}
